# ── 로컬 개발용 ──────────────────────────────────────────────────────────────
# Railway 배포 시에는 아래 변수명을 Railway 환경변수에 그대로 설정

# DB (Railway PostgreSQL 플러그인 → JDBC_DATABASE_URL 자동 제공)
JDBC_DATABASE_URL=jdbc:postgresql://localhost:5433/scanops
JDBC_DATABASE_USERNAME=scanops
JDBC_DATABASE_PASSWORD=scanops

# ZAP (Railway 배포 후 ZAP 서비스 URL로 교체)
ZAP_HOST=http://localhost:8090
ZAP_API_KEY=

# AI API Keys (Phase별 순차 추가)
OPENAI_API_KEY=your_openai_api_key
CLAUDE_API_KEY=your_claude_api_key
GEMINI_API_KEY=your_gemini_api_key

# CORS (Vercel 배포 후 실제 도메인 추가)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,https://*.vercel.app,https://*.up.railway.app

# Server (Railway가 PORT 자동 주입, 로컬은 8080)
PORT=8080
