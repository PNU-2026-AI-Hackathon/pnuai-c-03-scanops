# ScanOps V15 앙상블 API 이미지 (v13 ∨ v14 OR)
# 빌드 컨텍스트 = 레포 루트:  docker build -f Dockerfile.v15 -t scanops-v15-api .
FROM python:3.11-slim

WORKDIR /app
RUN apt-get update && apt-get install -y --no-install-recommends build-essential \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir \
    fastapi>=0.100 uvicorn[standard]>=0.23 pydantic>=2.0 \
    requests>=2.31 httpx>=0.27 python-dotenv>=1.0 \
    qdrant-client>=1.9 sentence-transformers>=2.7

COPY scripts/ ./scripts/
COPY scanops/ ./scanops/

ENV PYTHONPATH=/app
ENV PYTHONUNBUFFERED=1
# Ollama·모델은 환경변수로 주입 (compose에서 설정)
ENV OLLAMA_URL=http://ollama:11434
ENV SCANOPS_V13_MODEL=qwen2.5-coder-security-v13-7b:latest
ENV SCANOPS_V14_MODEL=qwen2.5-coder-security-v14-7b:latest

EXPOSE 8100
CMD ["sh", "-c", "uvicorn scripts.api_v15:app --host 0.0.0.0 --port ${PORT:-8100}"]
