# ── 로컬 개발 ────────────────────────────────────────────────
# Qdrant (로컬: docker-compose up 또는 brew)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=cve_vulnerabilities

# Ollama (로컬: brew services start ollama)
OLLAMA_URL=http://localhost:11434

# ── Railway 배포 환경변수 ─────────────────────────────────────
# Railway Qdrant 서비스 URL
# QDRANT_URL=https://qdrant-production-3ef0.up.railway.app

# Railway Ollama 서비스 URL
# OLLAMA_URL=https://ollama-production-ac66.up.railway.app

# FastAPI 서버 포트 (Railway가 자동 주입, 로컬 기본값 8100)
PORT=8100

# ── 모델 설정 ─────────────────────────────────────────────────
# Stage 1: QLoRA 파인튜닝 모델 (HuggingFace: SehanKim/qwen2.5-coder-security-v2-gguf)
# Stage 2: Base 모델 fallback
OLLAMA_MODEL=qwen2.5-coder:1.5b
