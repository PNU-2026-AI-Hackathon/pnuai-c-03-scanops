# RunPod Serverless 워커 이미지 — V18 rebuild Qwen3.5-9B (llama.cpp)
# 모델은 네트워크 볼륨(/runpod-volume/serve/*.gguf)에서 로드 → 이미지에 미포함(경량).
#
# 빌드/푸시 (Apple Silicon에서 amd64 크로스빌드):
#   docker buildx build --platform linux/amd64 -f runpod/Dockerfile.rebuild \
#     -t hansekim31/scanops-rebuild-worker:latest --push .
FROM ghcr.io/ggml-org/llama.cpp:server-cuda

RUN apt-get update && apt-get install -y --no-install-recommends \
        python3 python3-pip && \
    rm -rf /var/lib/apt/lists/* && \
    pip3 install --no-cache-dir --break-system-packages runpod requests

COPY runpod/handler_rebuild.py /handler.py

ENV MODEL_PATH=/runpod-volume/serve/scanops-rebuild-9b-q4km.gguf

# 베이스 이미지의 HEALTHCHECK(8080 /health)는 모델 로드 전엔 항상 실패해
# 서버리스 워커가 unhealthy로 강제 종료됨(크래시 루프) → 반드시 해제.
HEALTHCHECK NONE

ENTRYPOINT []
CMD ["python3", "-u", "/handler.py"]
